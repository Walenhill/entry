# Database configuration
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=booking_db
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# Master password for admin login (initial password, will be hashed and stored in DB)
MASTER_PASSWORD=change_this_master_password

# Application settings
APP_ENV=development
APP_DEBUG=true

# Telegram Bot Integration
BOT_TOKEN=your_telegram_bot_token_here
# Comma-separated list of Telegram User IDs for Admin access
ADMIN_TG_IDS=123456789,987654321
