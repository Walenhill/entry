# Database configuration
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=booking_db
DB_USERNAME=root
DB_PASSWORD=your_secure_password_here

# Master password for API authentication
MASTER_PASSWORD=change_this_master_password

# Secret key for token generation (change in production!)
SECRET_KEY=your-secret-key-change-in-production

# Application settings
APP_ENV=development
APP_DEBUG=true
