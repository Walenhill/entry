*.swo

# Environment
.env
.env.local
.env.*

# Editors
.vscode/
.idea/
*.swp
*.swo

# OS specific
.DS_Store
Thumbs.db

# Coverage
coverage/
htmlcov/
.coverage

# Python specific
*.pyc
__pycache__/
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/

# PHP specific
vendor/
composer.lock

# Build/cache directories
.mypy_cache/
.pytest_cache/
.gradle/
.npm/
.yarn/
```